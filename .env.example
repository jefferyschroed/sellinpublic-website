# Google Analytics / Search Console
SEO_AEO_CONFIG=config/seo-aeo.config.json
GOOGLE_CREDENTIAL_MODE=oauth
# Current mode is OAuth; leave the service-account path unused unless Google Cloud policy changes.
GOOGLE_APPLICATION_CREDENTIALS=secrets/google-service-account.json
GOOGLE_OAUTH_CREDENTIALS=secrets/google-oauth.json
GOOGLE_OAUTH_EXPECTED_EMAIL=owner@example.com
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CREDENTIALS_JSON=
GA4_PROPERTY_ID=542210968
GA4_MEASUREMENT_ID=G-QCYHK55RCG
GSC_SITE_URL=sc-domain:sellinpublic.co

# Google Search Console verification, when using meta tag verification.
GSC_VERIFICATION_TOKEN=

# Bing Webmaster Tools search performance. API key is secret.
BING_WEBMASTER_SITE_URL=https://sellinpublic.co
BING_WEBMASTER_API_KEY=

# Reddit Data API is intentionally disabled/not planned.
SEO_AEO_REDDIT_ENABLED=false
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# Optional approved Google Trends API endpoint, if access is granted.
GOOGLE_TRENDS_API_ENDPOINT=
GOOGLE_TRENDS_API_KEY=

# Official Google Trends RSS discovery lane. Disabled by default; rows are discovery-only.
SEO_AEO_GOOGLE_TRENDS_RSS_ENABLED=false
