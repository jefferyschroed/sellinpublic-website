{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sellinpublic.co/schemas/ai-citation-query-set.schema.json",
  "title": "Sell In Public AI Citation Query Set",
  "type": "object",
  "required": [
    "schema_version",
    "query_set_id",
    "query_set_version",
    "status",
    "effective_start_date",
    "cadence",
    "surfaces",
    "queries",
    "rule"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "query_set_id": { "type": "string", "minLength": 1 },
    "query_set_version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["active", "paused", "retired"] },
    "effective_start_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "cadence": { "type": "string", "minLength": 1 },
    "timezone": { "type": "string" },
    "default_country": { "type": "string" },
    "default_language": { "type": "string" },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["surface_id", "active"],
        "properties": {
          "surface_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "active": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["query_id", "query", "intent", "target_page_url", "active", "effective_start_date"],
        "properties": {
          "query_id": { "type": "string", "minLength": 1 },
          "query": { "type": "string", "minLength": 1 },
          "intent": { "type": "string" },
          "pillar_id": { "type": "string" },
          "topic_id": { "type": "string" },
          "target_slug": { "type": "string" },
          "target_page_url": { "type": "string", "minLength": 1 },
          "priority": { "type": "string" },
          "active": { "type": "boolean" },
          "effective_start_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        },
        "additionalProperties": true
      }
    },
    "rule": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
