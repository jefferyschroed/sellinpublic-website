{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sellinpublic.co/schemas/daily-discovery-rollup.schema.json",
  "title": "Daily Discovery Rollup",
  "description": "Content model for daily-discovery-rollup.md. The Markdown rollup should include these sections and facts.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_date",
    "inputs",
    "new_canonical_queries_count",
    "cluster_changes",
    "packet_candidates",
    "source_gaps",
    "sme_questions",
    "qa"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$"
    },
    "run_date": {
      "type": "string",
      "format": "date"
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inputSummary"
      }
    },
    "new_canonical_queries_count": {
      "type": "integer",
      "minimum": 0
    },
    "rising_gsc_queries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "google_trends_movement": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reddit_discovery_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ai_prompt_discovery_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cluster_changes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clusterChange"
      }
    },
    "packet_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sme_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "qa": {
      "$ref": "#/$defs/qa"
    }
  },
  "$defs": {
    "inputSummary": {
      "type": "object",
      "required": [
        "source_type",
        "status",
        "artifact"
      ],
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "collected",
            "missing",
            "skipped",
            "blocked"
          ]
        },
        "artifact": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "clusterChange": {
      "type": "object",
      "required": [
        "cluster_id",
        "change_type",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "cluster_id": {
          "type": "string"
        },
        "change_type": {
          "type": "string",
          "enum": [
            "created",
            "changed",
            "merged",
            "split",
            "monitored",
            "rejected"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "qa": {
      "type": "object",
      "required": [
        "all_rows_discovery_only",
        "reddit_not_used_as_evidence",
        "ai_prompt_not_used_as_evidence",
        "citations_unchanged",
        "analytics_csvs_unchanged",
        "connector_scripts_unchanged"
      ],
      "additionalProperties": false,
      "properties": {
        "all_rows_discovery_only": {
          "type": "boolean",
          "const": true
        },
        "reddit_not_used_as_evidence": {
          "type": "boolean",
          "const": true
        },
        "ai_prompt_not_used_as_evidence": {
          "type": "boolean",
          "const": true
        },
        "citations_unchanged": {
          "type": "boolean",
          "const": true
        },
        "analytics_csvs_unchanged": {
          "type": "boolean",
          "const": true
        },
        "connector_scripts_unchanged": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
