{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sellinpublic.co/schemas/dedupe-map.schema.json",
  "title": "Discovery Dedupe Map",
  "description": "Row model for dedupe-map.csv. Convert CSV rows to objects before validation.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_date",
    "rows"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$"
    },
    "run_date": {
      "type": "string",
      "format": "date"
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/row"
      }
    }
  },
  "$defs": {
    "row": {
      "type": "object",
      "required": [
        "duplicate_id",
        "canonical_query_id",
        "duplicate_query_id",
        "match_type",
        "match_confidence",
        "merge_decision",
        "reason",
        "reviewer",
        "reviewed_at"
      ],
      "additionalProperties": false,
      "properties": {
        "duplicate_id": {
          "type": "string",
          "pattern": "^dup-[a-z0-9-]+$"
        },
        "canonical_query_id": {
          "type": "string",
          "pattern": "^q-[a-z0-9-]+$"
        },
        "duplicate_query_id": {
          "type": "string",
          "pattern": "^q-[a-z0-9-]+$"
        },
        "match_type": {
          "type": "string",
          "enum": [
            "exact",
            "near",
            "semantic",
            "not_duplicate"
          ]
        },
        "match_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "merge_decision": {
          "type": "string",
          "enum": [
            "merge",
            "keep_separate",
            "needs_review"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "reviewer": {
          "type": "string"
        },
        "reviewed_at": {
          "type": "string"
        }
      }
    }
  }
}
