{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sellinpublic.co/schemas/query-clusters.schema.json",
  "title": "Discovery Query Clusters",
  "description": "Model for query-clusters.yaml after YAML-to-JSON conversion.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "updated_at",
    "rule",
    "clusters"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$"
    },
    "updated_at": {
      "type": "string"
    },
    "rule": {
      "type": "string",
      "minLength": 1
    },
    "clusters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/cluster"
      }
    }
  },
  "$defs": {
    "sourceType": {
      "type": "string",
      "enum": [
        "reddit_manual_capture",
        "reddit_api_export",
        "answer_the_public_export",
        "gsc_emerging_query_export",
        "bing_webmaster_query_export",
        "google_trends_api_export",
        "google_trends_csv_export",
        "public_source_trend_export",
        "manual_ai_prompt_export",
        "manual_serp_observation",
        "manual_topic_seed",
        "other_query_tool_export"
      ]
    },
    "cluster": {
      "type": "object",
      "required": [
        "cluster_id",
        "label",
        "intent",
        "pillar_id",
        "topic_id",
        "representative_query",
        "canonical_query_ids",
        "source_ids",
        "source_types",
        "cluster_confidence",
        "recommended_asset",
        "decision",
        "source_readiness",
        "evidence_use",
        "excluded_sources_for_evidence",
        "source_gaps",
        "sme_questions",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "cluster_id": {
          "type": "string",
          "pattern": "^cluster-[a-z0-9-]+$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "pillar_id": {
          "type": "string"
        },
        "topic_id": {
          "type": "string"
        },
        "representative_query": {
          "type": "string",
          "minLength": 1
        },
        "canonical_query_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^q-[a-z0-9-]+$"
          }
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "source_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/sourceType"
          }
        },
        "cluster_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "recommended_asset": {
          "type": "string",
          "enum": [
            "post",
            "post_plus_sections",
            "refresh",
            "faq",
            "section",
            "comparison_table",
            "monitor_only",
            "reject"
          ]
        },
        "topic_score": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 100
        },
        "decision": {
          "type": "string",
          "enum": [
            "create_packet",
            "refresh_packet",
            "map_as_section",
            "map_as_faq",
            "monitor",
            "reject"
          ]
        },
        "source_readiness": {
          "type": "string",
          "enum": [
            "ready_for_source_review",
            "needs_source_discovery",
            "needs_sme_review",
            "discovery_only_monitor",
            "rejected"
          ]
        },
        "evidence_use": {
          "type": "string",
          "const": "discovery_only"
        },
        "excluded_sources_for_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sme_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
